generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String?  @unique
  phone         String   @unique
  password      String?
  name          String?
  role          String   @default("USER")
  depositBalance  Float    @default(0.0)
  winningBalance  Float    @default(0.0)
  bonusBalance    Float    @default(0.0)
  totalWinnings   Float    @default(0.0)
  referredBy      String?
  referralCode    String?  @unique
  referralEarnings Float @default(0.0)
  createdAt     DateTime @default(now())
  
  transactions  Transaction[]
  otps          Otp[]
  
  matchesAsPlayer1 Match[] @relation("Player1Matches")
  matchesAsPlayer2 Match[] @relation("Player2Matches")
  matchesWon       Match[] @relation("MatchWinner")
}

model Otp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model Transaction {
  id        String   @id @default(cuid())
  amount    Float
  type      String   // "DEPOSIT", "WITHDRAWAL", "GAME_WIN", "GAME_LOSS"
  status    String   // "PENDING", "SUCCESS", "FAILED"
  gateway   String   // "RAZORPAY", "PAYTM", "SYSTEM"
  orderId   String?  // Gateway Order ID
  paymentDetails String? // UPI ID or Bank Info for withdrawals
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Match {
  id        String   @id @default(cuid())
  entryFee  Float
  status    String   // "WAITING", "PLAYING", "FINISHED", "CANCELLED"
  
  player1Id String
  player1   User     @relation("Player1Matches", fields: [player1Id], references: [id])
  
  player2Id String?
  player2   User?    @relation("Player2Matches", fields: [player2Id], references: [id])
  
  gameState String?  @default("{}")
  
  winnerId  String?
  winner    User?    @relation("MatchWinner", fields: [winnerId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
